// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ──────────────────────────────────────────────
// 1. User (用户)
// ──────────────────────────────────────────────
model User {
  id           String    @id @default(cuid()) @map("id")
  name         String    @map("name")
  phone        String    @unique @map("phone")
  passwordHash String    @map("password_hash")
  role         String    @map("role")
  organization String    @default("") @map("organization")
  community    String    @default("") @map("community")
  avatar       String?   @map("avatar")
  avatarColor  String?   @map("avatar_color")
  avatarEmoji  String?   @map("avatar_emoji")
  status       String    @default("active") @map("status")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLogin    DateTime? @map("last_login")

  // Relations: onDelete: Restrict – cannot delete a user if referenced
  eldersCreated     ElderProfile[]    @relation("Creator")
  tasksAssigned     Task[]            @relation("Assignee")
  casesAssigned     CaseEvent[]       @relation("CaseAssignee")
  dischargeAssigned DischargePlan[]   @relation("DischargeAssignee")
  followupAssigned  FollowupRecord[]  @relation("FollowupAssignee")
  auditLogs         AuditLog[]

  @@map("users")
}

// ──────────────────────────────────────────────
// 2. ElderProfile (长者档案)
// ──────────────────────────────────────────────
model ElderProfile {
  id                String   @id @default(cuid()) @map("id")
  name              String   @map("name")
  gender            String   @map("gender")
  age               Int      @map("age")
  livingStatus      String   @map("living_status")
  community         String   @map("community")
  address           String   @map("address")
  phone             String   @default("") @map("phone")
  medicalHistory    String   @default("") @map("medical_history")
  emergencyNotes    String   @default("") @map("emergency_notes")
  communicationPref String   @default("") @map("communication_pref")
  carePref          String   @default("") @map("care_pref")
  aidNeeds          String   @default("") @map("aid_needs")
  riskLevel         String   @default("medium") @map("risk_level")
  status            String   @default("draft") @map("status")
  createdById       String   @map("created_by_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  creator       User              @relation("Creator", fields: [createdById], references: [id], onDelete: Restrict)
  contacts      TrustedContact[]
  cards         EmergencyCard[]
  caseEvents    CaseEvent[]
  tasks         Task[]
  discharges    DischargePlan[]
  followups     FollowupRecord[]
  voiceRecords  VoiceRecord[]
  summaries     Summary[]
  medicalRecords MedicalRecord[]
  consents      Consent[]

  @@map("elder_profiles")
}

// ──────────────────────────────────────────────
// 3. TrustedContact (紧急联系人)
// ──────────────────────────────────────────────
model TrustedContact {
  id              String   @id @default(cuid()) @map("id")
  elderId         String   @map("elder_id")
  name            String   @map("name")
  relation        String   @map("relation")
  phone           String   @map("phone")
  priority        Int      @default(1) @map("priority")
  verifiedStatus  String   @default("pending") @map("verified_status")
  canMakeDecision Boolean  @default(false) @map("can_make_decision")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  elder ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)

  @@map("trusted_contacts")
}

// ──────────────────────────────────────────────
// 4. EmergencyCard (急救卡)
// ──────────────────────────────────────────────
model EmergencyCard {
  id              String    @id @default(cuid()) @map("id")
  elderId         String    @map("elder_id")
  cardNo          String    @unique @map("card_no")
  qrToken         String    @unique @map("qr_token")
  visibilityLevel String    @default("contact") @map("visibility_level")
  emergencyNote   String    @default("") @map("emergency_note")
  status          String    @default("active") @map("status")
  createdAt       DateTime  @default(now()) @map("created_at")
  printedAt       DateTime? @map("printed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  elder  ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)
  qrCode QrCode?

  @@map("emergency_cards")
}

// ──────────────────────────────────────────────
// 5. QrCode (二维码扫描记录)
// ──────────────────────────────────────────────
model QrCode {
  id           String    @id @default(cuid()) @map("id")
  cardId       String    @unique @map("card_id")
  token        String    @unique @map("token")
  scanCount    Int       @default(0) @map("scan_count")
  lastScannedAt DateTime? @map("last_scanned_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  card EmergencyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}

// ──────────────────────────────────────────────
// 6. Task (任务工单)
// ──────────────────────────────────────────────
model Task {
  id             String    @id @default(cuid()) @map("id")
  elderId        String    @map("elder_id")
  taskType       String    @map("task_type")
  title          String    @map("title")
  description    String    @default("") @map("description")
  status         String    @default("todo") @map("status")
  priority       Int       @default(2) @map("priority")
  assigneeId     String    @map("assignee_id")
  dueDate        DateTime  @map("due_date")
  completedAt    DateTime? @map("completed_at")
  completionNote String?   @map("completion_note")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  elder    ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)
  assignee User         @relation("Assignee", fields: [assigneeId], references: [id], onDelete: Restrict)

  @@map("tasks")
}

// ──────────────────────────────────────────────
// 7. CaseEvent (事件案例)
// ──────────────────────────────────────────────
model CaseEvent {
  id          String    @id @default(cuid()) @map("id")
  elderId     String    @map("elder_id")
  triggerType String    @map("trigger_type")
  description String    @map("description")
  status      String    @default("open") @map("status")
  severity    Int       @default(2) @map("severity")
  assigneeId  String    @map("assignee_id")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  elder    ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)
  assignee User         @relation("CaseAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)

  @@map("case_events")
}

// ──────────────────────────────────────────────
// 8. DischargePlan (出院计划)
// ──────────────────────────────────────────────
model DischargePlan {
  id                        String   @id @default(cuid()) @map("id")
  elderId                   String   @map("elder_id")
  caseId                    String   @map("case_id")
  hospitalName              String   @map("hospital_name")
  dischargeDate             DateTime @map("discharge_date")
  pickupStatus              String   @default("pending") @map("pickup_status")
  medicationReminderStatus  String   @default("pending") @map("medication_reminder_status")
  revisitStatus             String   @default("pending") @map("revisit_status")
  visitStatus               String   @default("pending") @map("visit_status")
  assigneeId                String   @map("assignee_id")
  notes                     String   @default("") @map("notes")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  // Relations
  elder    ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)
  assignee User         @relation("DischargeAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)

  @@map("discharge_plans")
}

// ──────────────────────────────────────────────
// 9. FollowupRecord (回访记录)
// ──────────────────────────────────────────────
model FollowupRecord {
  id            String    @id @default(cuid()) @map("id")
  elderId       String    @map("elder_id")
  caseId        String?   @map("case_id")
  type          String    @map("type")
  status        String    @default("scheduled") @map("status")
  scheduledDate DateTime  @map("scheduled_date")
  completedAt   DateTime? @map("completed_at")
  result        String    @default("") @map("result")
  satisfaction  Int?      @map("satisfaction")
  nextAction    String    @default("") @map("next_action")
  assigneeId    String    @map("assignee_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  elder    ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)
  assignee User         @relation("FollowupAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)

  @@map("followup_records")
}

// ──────────────────────────────────────────────
// 10. VoiceRecord (语音记录)
// ──────────────────────────────────────────────
model VoiceRecord {
  id         String   @id @default(cuid()) @map("id")
  elderId    String   @map("elder_id")
  fieldName  String   @map("field_name")
  audioUrl   String?  @map("audio_url")
  transcript String   @map("transcript")
  confidence Float?   @map("confidence")
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  elder ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)

  @@map("voice_records")
}

// ──────────────────────────────────────────────
// 11. Summary (档案摘要)
// ──────────────────────────────────────────────
model Summary {
  id           String    @id @default(cuid()) @map("id")
  elderId      String    @map("elder_id")
  versionNo    String    @map("version_no")
  content      String    @map("content")     // stores JSON string
  generatedBy  String    @default("rule_engine") @map("generated_by")
  reviewStatus String    @default("pending") @map("review_status")
  reviewedBy   String?   @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  elder ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)

  @@map("summaries")
}

// ──────────────────────────────────────────────
// 12. Consent (知情同意)
// ──────────────────────────────────────────────
model Consent {
  id        String   @id @default(cuid()) @map("id")
  elderId   String   @map("elder_id")
  versionNo String   @map("version_no")
  agreedBy  String   @map("agreed_by")
  relation  String   @default("本人") @map("relation")
  agreedAt  DateTime @default(now()) @map("agreed_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  elder ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)

  @@map("consents")
}

// ──────────────────────────────────────────────
// 13. MedicalRecord (医疗记录)
// ──────────────────────────────────────────────
model MedicalRecord {
  id              String    @id @default(cuid()) @map("id")
  elderId         String    @map("elder_id")
  type            String    @map("type")
  title           String    @map("title")
  imageUrl        String?   @map("image_url")
  ocrText         String?   @map("ocr_text")
  structuredData  String?   @map("structured_data")  // stores JSON string
  confidenceScore Float?    @map("confidence_score")
  reviewedBy      String?   @map("reviewed_by")
  reviewStatus    String    @default("pending") @map("review_status")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  elder ElderProfile @relation(fields: [elderId], references: [id], onDelete: Cascade)

  @@map("medical_records")
}

// ──────────────────────────────────────────────
// 14. AuditLog (审计日志)
// ──────────────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid()) @map("id")
  actorId      String   @map("actor_id")
  actorName    String   @map("actor_name")
  actorRole    String   @map("actor_role")
  action       String   @map("action")
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  ip           String   @default("") @map("ip")
  isAbnormal   Boolean  @default(false) @map("is_abnormal")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  actor User @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@map("audit_logs")
}
